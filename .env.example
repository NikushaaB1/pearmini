# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ერთხელ გაუშვი Supabase SQL Editor-ში:
# supabase/schema.sql   (სრული სქema)
# supabase/feed_posts.sql   (მხოლოდ პოსტები — თუ schema უკვე გაქვს)

# Authentication → Providers → Email → Enable
# Authentication → Providers → Email → Confirm email → OFF (ადმინის შექმნილი ანგარიშებისთვის)
#
# ანგარიშის შექმნისთვის (email rate limit-ის გარეშე):
# npx supabase login
# npx supabase link --project-ref YOUR_PROJECT_REF
# npx supabase functions deploy create-user
#
# AI (Google Gemini):
# npx supabase secrets set GEMINI_API_KEY=your_gemini_api_key
# npx supabase secrets set GEMINI_TEXT_MODEL=gemini-2.5-flash
# npx supabase secrets set GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Optional fallbacks: gemini-3.1-flash-image-preview, gemini-3-pro-image-preview
# npx supabase functions deploy gemini-assist
#
# ძველი OpenAI (არ არის საჭირო):
# npx supabase functions deploy ai-post-assist
